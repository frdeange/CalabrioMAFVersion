<policies>
  <!-- Host is derived from API Web service URL; set backend-url/Web service URL to the same DevTunnel port URL. -->
  <!-- CORS handled at API level via APIM built-in CORS policy. Do not add CORS handling here. -->
  <inbound>
    <base />
    <set-header name="Host" exists-action="override">
      <value>@(new System.Uri(context.Api.ServiceUrl.ToString()).Host)</value>
    </set-header>
  </inbound>
  <backend>
    <forward-request timeout="10" />
  </backend>
  <outbound>
    <base />
  </outbound>
  <on-error>
    <base />
  </on-error>
</policies>
