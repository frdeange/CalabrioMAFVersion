<policies>
  <!-- Host header: derived from Named Value "backend-url" so each developer can use their own DevTunnel URL. -->
  <inbound>
    <base />
    <set-backend-service base-url="{{backend-url}}" />
    <set-header name="Host" exists-action="override">
      <value>@(new System.Uri("{{backend-url}}").Host)</value>
    </set-header>
  </inbound>
  <backend>
    <base />
    <forward-request timeout="10" />
  </backend>
  <outbound>
    <base />
  </outbound>
  <on-error>
    <base />
  </on-error>
</policies>
