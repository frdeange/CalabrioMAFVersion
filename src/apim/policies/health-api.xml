<policies>
  <!-- Host is derived from API Web service URL; set backend-url/Web service URL to the same DevTunnel port URL. -->
  <inbound>
    <base />
    <choose>
      <when condition="@(context.Request.Method == &quot;OPTIONS&quot;)">
        <return-response>
          <set-status code="200" reason="OK" />
          <set-header name="Access-Control-Allow-Origin" exists-action="override">
            <value>@(context.Request.Headers.GetValueOrDefault("Origin",""))</value>
          </set-header>
          <set-header name="Access-Control-Allow-Methods" exists-action="override">
            <value>GET, OPTIONS</value>
          </set-header>
          <set-header name="Access-Control-Allow-Headers" exists-action="override">
            <value>Authorization, Content-Type, Accept</value>
          </set-header>
          <set-header name="Access-Control-Allow-Credentials" exists-action="override">
            <value>true</value>
          </set-header>
          <set-header name="Access-Control-Max-Age" exists-action="override">
            <value>3600</value>
          </set-header>
        </return-response>
      </when>
    </choose>
    <set-header name="Host" exists-action="override">
      <value>@(new System.Uri(context.Api.ServiceUrl.ToString()).Host)</value>
    </set-header>
  </inbound>
  <backend>
    <forward-request timeout="10" />
  </backend>
  <outbound>
    <base />
  </outbound>
  <on-error>
    <base />
  </on-error>
</policies>
