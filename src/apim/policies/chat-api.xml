<policies>
  <!-- Host is derived from API Web service URL; set backend-url/Web service URL to the same DevTunnel port URL. -->
  <!-- CORS handled at API level via APIM built-in CORS policy. Do not add CORS handling here. -->
  <inbound>
    <base />

    <!-- Validate Entra ID v2.0 access token (multi-tenant via common metadata). -->
    <validate-jwt
      header-name="Authorization"
      failed-validation-httpcode="401"
      failed-validation-error-message="Unauthorized"
      require-expiration-time="true"
      require-signed-tokens="true">
      <openid-config url="https://login.microsoftonline.com/common/v2.0/.well-known/openid-configuration" />
      <audiences>
        <audience>api://9dfbf018-d41b-4579-8b6c-e58d1a9a52be</audience>
      </audiences>
    </validate-jwt>

    <!-- Inject identity context for downstream services. -->
    <set-header name="x-user-oid" exists-action="override">
      <value>@(context.Request.Headers.GetValueOrDefault("Authorization","").AsJwt()?.Claims.GetValueOrDefault("oid",""))</value>
    </set-header>
    <set-header name="x-user-tid" exists-action="override">
      <value>@(context.Request.Headers.GetValueOrDefault("Authorization","").AsJwt()?.Claims.GetValueOrDefault("tid",""))</value>
    </set-header>
    <set-header name="x-user-name" exists-action="override">
      <value>@(context.Request.Headers.GetValueOrDefault("Authorization","").AsJwt()?.Claims.GetValueOrDefault("name",""))</value>
    </set-header>
    <set-header name="x-user-email" exists-action="override">
      <value>@(context.Request.Headers.GetValueOrDefault("Authorization","").AsJwt()?.Claims.GetValueOrDefault("preferred_username",""))</value>
    </set-header>

    <!-- Per-user throttling (60 calls/minute). -->
    <rate-limit-by-key
      calls="60"
      renewal-period="60"
      counter-key="@(context.Request.Headers.GetValueOrDefault(&quot;Authorization&quot;,&quot;&quot;).AsJwt()?.Claims.GetValueOrDefault(&quot;oid&quot;, context.Request.IpAddress))" />

    <!-- TODO: Add HMAC signing for x-user-* headers once Key Vault secret wiring is ready. -->
    <set-header name="Host" exists-action="override">
      <value>@(new System.Uri(context.Api.ServiceUrl.ToString()).Host)</value>
    </set-header>
  </inbound>

  <backend>
    <forward-request timeout="30" />
  </backend>

  <outbound>
    <base />

    <!-- Prevent internal identity headers from leaking to clients. -->
    <set-header name="x-user-oid" exists-action="delete" />
    <set-header name="x-user-tid" exists-action="delete" />
    <set-header name="x-user-name" exists-action="delete" />
    <set-header name="x-user-email" exists-action="delete" />
  </outbound>

  <on-error>
    <base />
    <set-header name="Content-Type" exists-action="override">
      <value>application/json</value>
    </set-header>
    <set-body>{"error":"apim_request_failed","message":"Request could not be processed by API Management."}</set-body>
  </on-error>
</policies>
