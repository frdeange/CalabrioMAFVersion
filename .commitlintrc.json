{
  "rules": {
    "type-empty": [
      2,
      "never"
    ],
    "subject-empty": [
      2,
      "never"
    ],
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "fix",
        "chore",
        "docs",
        "test",
        "refactor",
        "ci",
        "perf"
      ]
    ]
  }
}

