# Copy to `.env`, fill values from `docs/sandbox-deployment-checklist.md` YAML once Kiko provisions the sandbox.
# `.env` is gitignored.

# Shared runtime settings (local/dev/sandbox)
ENVIRONMENT=local
LOG_LEVEL=INFO

# Azure Monitor / Application Insights connection string
APP_INSIGHTS_CONNECTION_STRING=

# Agent Host endpoints (Foundry + APIM)
FOUNDRY_PROJECT_ENDPOINT=
APIM_GATEWAY_URL=

# Downstream service URLs from Agent Host to MCPs
MCP_WFM_URL=http://mcp-wfm:8001/mcp
MCP_FORECAST_URL=http://mcp-forecast:8002/mcp

# Container service ports
MCP_WFM_PORT=8001
MCP_FORECAST_PORT=8002

# Sandbox placeholders from provisioning checklist (keep synthetic data only)
COSMOS_ENDPOINT=
KEYVAULT_URI=
CONTENT_SAFETY_ENDPOINT=
