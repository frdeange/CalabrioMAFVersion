# Foundry Agent Service
FOUNDRY_PROJECT_ENDPOINT=https://your-foundry-resource.services.ai.azure.com/api/projects/your-project
MODEL_DEPLOYMENT=gpt-5.2
INTENT_AGENT_NAME=wfm-intent-classifier
SQL_BUILDER_AGENT_NAME=wfm-sql-builder
QUERY_EXECUTOR_AGENT_NAME=wfm-query-executor

# MCP WFM
MCP_WFM_URL=http://mcp-wfm:8001/mcp
MCP_WFM_PORT=8001

# Azure SQL (Managed Identity in cloud, connection string local)
SQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=your-sql-server.database.windows.net;Database=your-database;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30
SQL_MANAGED_IDENTITY_CLIENT_ID=your-managed-identity-client-id

# Optional service principal auth in Docker
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# MSAL / Entra ID (fill after app registration)
MSAL_CLIENT_ID=your-msal-client-id
MSAL_TENANT_ID=your-tenant-id

# Observability
ENVIRONMENT=local
LOG_LEVEL=INFO
APP_INSIGHTS_CONNECTION_STRING=
