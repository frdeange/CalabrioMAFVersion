# Copy to `docker-compose.override.yml` to enable; gitignored automatically by Docker Compose convention.
services:
  agent-host:
    volumes:
      - .\src\agent_host\app:/app/app
      - .\src\agent_host\tests:/app/tests
    command: ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]

  mcp-wfm:
    volumes:
      - .\src\mcp_wfm\app:/app/app
      - .\src\mcp_wfm\tests:/app/tests
    command: ["uvicorn", "app.server:app", "--host", "0.0.0.0", "--port", "8001", "--reload"]

  mcp-forecast:
    volumes:
      - .\src\mcp_forecast\app:/app/app
      - .\src\mcp_forecast\tests:/app/tests
    command: ["uvicorn", "app.server:app", "--host", "0.0.0.0", "--port", "8002", "--reload"]
